# ── LLM Provider ──────────────────────────────────────
# Options: anthropic | openai | deepseek | openrouter
AGENT_PROVIDER=anthropic

# ── API Keys (set at least one for your provider) ─────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
BRAVE_SEARCH_API_KEY=

# ── Base URLs (optional, for custom endpoints) ────────
# OpenAI-compatible (DeepSeek, OpenRouter, Ollama, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# ANTHROPIC_BASE_URL=

# ── Model ─────────────────────────────────────────────
MODEL_NAME=claude-sonnet-4-6

# ── Agent Behavior ────────────────────────────────────
AGENT_MAX_ITERATIONS=10
AGENT_MAX_TOKENS=8000
AGENT_TIMEOUT=300
AGENT_BASH_TIMEOUT=120
AGENT_WORK_DIR=
AGENT_CHARTS_DIR=

# ── Memory ────────────────────────────────────────────
AGENT_MEMORY_WINDOW=10
AGENT_MEMORY_MAX_LINES=200
# AGENT_MEMORY_FILE=
# AGENT_REFLECTION_FILE=
# AGENT_LONG_TERM_DB=
# AGENT_REFLEXION_DB=

# ── Strategy Parameters ───────────────────────────────
AGENT_REACT_MAX_STEPS=10
AGENT_REFLEXION_MAX_RETRIES=3
AGENT_TOT_CANDIDATES=3
AGENT_TOT_SCORE_THRESHOLD=6

# ── Orient ────────────────────────────────────────────
AGENT_ORIENT_MIN_CHARS=200

# ── Tool Limits ───────────────────────────────────────
AGENT_BASH_OUTPUT_LIMIT=50000
AGENT_FETCH_MAX_CHARS=8000

# ── Rules / Skills ────────────────────────────────────
AGENT_RULES_DIR=.agent/rules
AGENT_SKILLS_DIR=.agent/skills

# ── Logging ────────────────────────────────────────────
# AGENT_LOG_LEVEL=INFO
# AGENT_LOG_FORMAT=text    # text|json (json for structured logging)
# AGENT_LOG_FILE=

# ── Chart Verification ────────────────────────────────
# Enable vision LLM to visually verify generated charts
# AGENT_CHART_VERIFY=false

# ── Security ──────────────────────────────────────────
# Set to true for public-facing deployments (restricts dangerous tools)
AGENT_PUBLIC_MODE=false

# ── Simulation ───────────────────────────────────────
# Path to ngspice binary
AGENT_SIM_PATH=ngspice
# Simulation timeout in seconds
AGENT_SIM_TIMEOUT=30

# ── Web Server ────────────────────────────────────────
WEB_PORT=8080
DAILY_LIMIT_PER_USER=0
WEB_ACCESS_CODE=
